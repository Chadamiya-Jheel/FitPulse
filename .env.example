# ============================================================
#  FitPulse — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to source control.
# ============================================================

# ----- Flask ------------------------------------------------
SECRET_KEY=your-very-secret-flask-key-change-me
FLASK_ENV=development
FLASK_DEBUG=1

# ----- Database ---------------------------------------------
DATABASE_URL=sqlite:///fitpulse.db

# ----- IBM watsonx.ai ---------------------------------------
# Get these from https://cloud.ibm.com/
WATSONX_API_KEY=your-ibm-cloud-api-key-here
WATSONX_PROJECT_ID=your-watsonx-project-id-here
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# ----- IBM Granite Model ------------------------------------
# Available models: ibm/granite-13b-chat-v2, ibm/granite-3-8b-instruct
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# ----- App Config -------------------------------------------
APP_NAME=FitPulse
MAX_CHAT_HISTORY=20
